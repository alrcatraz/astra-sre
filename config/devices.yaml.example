# astra-sre device inventory (example template)
# Copy this file to devices.yaml and fill in your actual infrastructure.

devices:
  - name: server-1
    role: Primary server
    desc: Your server description here
    os: Debian 12
    ssh: user@your-server-ip
    ssh_port: 22
    key: id_ed25519
    checks:
      - systemd: [sshd, nginx, postgresql]
      - port: [22, 80, 443]
      - disk_warn: 85
      - disk_crit: 92

  - name: nas-1
    role: Storage
    desc: Your NAS description here
    os: DSM 7.x
    ssh: user@nas-ip
    checks:
      - disk_warn: 85
      - disk_crit: 92
